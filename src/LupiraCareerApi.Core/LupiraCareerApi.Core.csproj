<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Keep the LupiraCareerApi.* namespaces unchanged across the project split. -->
    <RootNamespace>LupiraCareerApi</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Marten is the event store + document store on Postgres. No ASP.NET dependency — that lives in the host. -->
    <PackageReference Include="Marten" Version="9.6.0" />
  </ItemGroup>

</Project>
